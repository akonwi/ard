fn lists_page(c: mut ffi::StateCtx, s: DemoState, theme: ui::Theme) ui::Widget {
  ui::Flex{
    Axis: ui::Vertical,
    CrossAxisAlignment: ui::CrossAxisStretch,
    Children: [
      ui::RichText{
        Spans: [
          ui::TextSpan{Text: "Lists", Style: bold()},
          ui::TextSpan{Text: "  mixed slivers, lazy rows, and follow-output logs"},
        ],
        SoftWrap: true,
      },
      ui::SizedBox{Height: 1},
      list_tile("•", "Deploy queue", "2 running, 4 queued", "open", "Deploy queue"),
      list_tile("✓", "Checks passing", "", "12/12", "Checks passing"),
      ui::SizedBox{Height: 1},
      ui::SizedBox{
        Width: 72,
        Height: 5,
        Child: ui::Scrollbar{
          Child: ui::CustomScrollView{
            Slivers: [
              ui::SliverToBox{
                Child: ui::Text{Value: "The intro sliver scrolls away before the pinned header takes over.", SoftWrap: true},
              },
              ui::SliverPinnedHeader{
                Child: ui::Text{
                  Value: " #  target             status",
                  Style: ui::Style{
                    Attribute: ui::AttrBold,
                    Foreground: theme.Foreground,
                    Background: theme.Surface,
                  },
                },
              },
              ui::SliverListBuilder{
                Count: 2000,
                ItemExtent: 1,
                Overscan: 12,
                Builder: fn(bctx: ui::BuildContext, i: Int) ui::Widget {
                  list_demo_row(theme, i + 1)
                },
              },
            ],
          },
        },
      },
      ui::SizedBox{Height: 1},
      ui::TextField{
        Value: s.chat,
        Placeholder: "echo a message",
        MinWidth: 72,
        OnChanged: fn(ev: ui::EventContext, value: Str) {
          set_chat(c, value)
        },
        OnSubmitted: fn(ev: ui::EventContext, value: Str) {
          submit_chat(c, value)
        },
      },
      ui::SizedBox{Height: 1},
      ui::Text{Value: "Variable-height messages", Style: bold()},
      ui::SizedBox{
        Width: 72,
        Height: 4,
        Child: ui::Scrollbar{
          Child: ui::CustomScrollView{
            FollowOutput: true,
            Slivers: [
              ui::SliverListBuilder{
                Count: s.logs.size(),
                EstimatedItemExtent: 2,
                Overscan: 8,
                Builder: fn(bctx: ui::BuildContext, i: Int) ui::Widget {
                  chat_message(i, s.logs.at(i))
                },
              },
            ],
          },
        },
      },
    ],
  }
}

// 24 rows of scrollable content, built with a range loop + list push.
fn scroll_demo_lines() ui::Widget {
  mut rows: [ui::Widget] = []
  for i in 1..24 {
    rows.push(
      ui::RichText{
        Spans: [
          ui::TextSpan{Text: "row {i}", Style: bold()},
          ui::TextSpan{Text: "  scrollable content for the demo viewport"},
        ],
      },
    )
  }
  ui::Flex{
    Axis: ui::Vertical,
    CrossAxisAlignment: ui::CrossAxisStart,
    Children: rows,
  }
}

fn horizontal_scroll_demo_line() Str {
  "col-001 alpha  |  col-002 beta  |  col-003 gamma  |  col-004 delta  |  col-005 epsilon  |  col-006 zeta  |  col-007 eta"
}

fn pad2(n: Int) Str {
  match n < 10 {
    true => "0{n}",
    false => "{n}",
  }
}

// An 18x10 grid of labels, built with nested range loops + string interpolation.
fn scroll_pane_demo_text() Str {
  mut text = ""
  for r in 1..18 {
    mut line = ""
    for col in 1..10 {
      line = "{line}r{pad2(r)}c{pad2(col)}  "
    }
    text = "{text}{line}\n"
  }
  text
}

