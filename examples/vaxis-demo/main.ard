  ui::Flex{
    Axis: ui::Vertical,
    CrossAxisAlignment: ui::CrossAxisStart,
    Children: [
      ui::RichText{
        Spans: [
          ui::TextSpan{Text: "Home", Style: bold()},
          ui::TextSpan{
            Text: "\nA pure-Ard reimplementation of the vaxis/ui demo, exercising state, focus, buttons, rich text, themed widgets, and generics over the Go framework.",
          },
        ],
        SoftWrap: true,
      },
      ui::SizedBox{Height: 1},
      ui::Text{
        Value: "The ticker below is incremented by a background goroutine posting through Runtime.Dispatch, which then schedules a rebuild.",
        SoftWrap: true,
      },
      ui::RichText{Spans: [ui::TextSpan{Text: "ticks: "}, ui::TextSpan{Text: "{s.ticks}", Style: bold()}]},
    ],
  }
}

