use go:go.rockorager.dev/vaxis/ui
use go:go.rockorager.dev/vaxis/widgets/term
use go:strconv
use go:vaxis_demo/ffi

struct DemoState {
  page: Int,
  count: Int,
  ticks: Int,
  name: Str,
  notes: Str,
  done: Bool,
  dialog: Bool,
  palette: Bool,
  mode: Str,
  chat: Str,
  logs: [Str],
}

// Runs ~1/sec on the UI thread (via the shim's goroutine + Runtime.Dispatch).
fn tick(c: mut ffi::StateCtx) {
  let state = ffi::StateRef<DemoState>(c)
  state.ticks = state.ticks + 1
  ffi::MarkDirty(c)
}

// --- state update helpers ---
// Reference-mutation model: StateRef hands back a `mut DemoState` (a live
// pointer into the persistent state, via Go `*T`), so each setter mutates its
// field in place and calls MarkDirty to schedule a rebuild. No snapshot copy
// and no whole-value write-back. Adding a field to DemoState needs no changes
// here.

fn set_page(c: mut ffi::StateCtx, v: Int) {
  let state = ffi::StateRef<DemoState>(c)
  state.page = v
  ffi::MarkDirty(c)
}

fn set_count(c: mut ffi::StateCtx, v: Int) {
  let state = ffi::StateRef<DemoState>(c)
  state.count = v
  ffi::MarkDirty(c)
}

fn set_name(c: mut ffi::StateCtx, v: Str) {
  let state = ffi::StateRef<DemoState>(c)
  state.name = v
  ffi::MarkDirty(c)
}

fn set_notes(c: mut ffi::StateCtx, v: Str) {
  let state = ffi::StateRef<DemoState>(c)
  state.notes = v
  ffi::MarkDirty(c)
}

fn set_done(c: mut ffi::StateCtx, v: Bool) {
  let state = ffi::StateRef<DemoState>(c)
  state.done = v
  ffi::MarkDirty(c)
}

fn set_dialog(c: mut ffi::StateCtx, v: Bool) {
  let state = ffi::StateRef<DemoState>(c)
  state.dialog = v
  ffi::MarkDirty(c)
}

fn set_palette(c: mut ffi::StateCtx, v: Bool) {
  let state = ffi::StateRef<DemoState>(c)
  state.palette = v
  ffi::MarkDirty(c)
}

// Palette actions close the palette as they run.
fn goto_page(c: mut ffi::StateCtx, page: Int) {
  let state = ffi::StateRef<DemoState>(c)
  state.page = page
  state.palette = false
  ffi::MarkDirty(c)
}

fn open_dialog_from_palette(c: mut ffi::StateCtx) {
  let state = ffi::StateRef<DemoState>(c)
  state.palette = false
  state.dialog = true
  ffi::MarkDirty(c)
}

fn replay_animation(c: mut ffi::StateCtx) {
  let anim = ffi::Animation(c)
  anim.Forward()
  set_palette(c, false)
}

fn palette_nav_item(c: mut ffi::StateCtx, label: Str, name: Str, page: Int) ui::CommandPaletteItem {
  ui::CommandPaletteItem{
    Title: "Go to {label}",
    Description: "Open the {name} demo page",
    Aliases: [name, "page"],
    OnSelected: fn(ev: ui::EventContext) {
      goto_page(c, page)
    },
  }
}

fn command_palette_items(c: mut ffi::StateCtx) [ui::CommandPaletteItem] {
  mut items: [ui::CommandPaletteItem] = [
    palette_nav_item(c, "Home", "home", 0),
    palette_nav_item(c, "Text layout", "text", 1),
    palette_nav_item(c, "Controls", "controls", 2),
    palette_nav_item(c, "Lists", "lists", 3),
    palette_nav_item(c, "Table", "table", 4),
    palette_nav_item(c, "Animation", "animation", 5),
    palette_nav_item(c, "Theme", "theme", 6),
  ]
  items.push(
    ui::CommandPaletteItem{
      Title: "Open dialog",
      Description: "Show the modal dialog example",
      Aliases: ["modal"],
      OnSelected: fn(ev: ui::EventContext) {
        open_dialog_from_palette(c)
      },
    },
  )
  items.push(
    ui::CommandPaletteItem{
      Title: "Replay animation",
      Description: "Start the animation controller",
      Aliases: ["play"],
      OnSelected: fn(ev: ui::EventContext) {
        replay_animation(c)
      },
    },
  )
  items.push(
    ui::CommandPaletteItem{
      Title: "Send notification",
      Description: "Show a demo notification",
      Aliases: ["notify"],
      OnSelected: fn(ev: ui::EventContext) {
        ev.Notify("Vaxis UI demo", "Command palette action")
        set_palette(c, false)
      },
    },
  )
  items.push(
    ui::CommandPaletteItem{
      Title: "Quit",
      Description: "Exit the demo",
      Aliases: ["exit"],
      OnSelected: fn(ev: ui::EventContext) {
        ev.Quit()
      },
    },
  )
  items
}

// A modal command-palette overlay entry, shown when state.palette is set.
fn palette_entry(c: mut ffi::StateCtx) ui::OverlayEntry {
  ui::OverlayEntry{
    Modal: true,
    Child: ui::CommandPalette{
      Items: command_palette_items(c),
      Placeholder: "Type a command…",
      OnDismiss: fn(ev: ui::EventContext) {
        set_palette(c, false)
      },
    },
  }
}

// A modal dialog overlay entry, shown when state.dialog is set.
fn dialog_entry(c: mut ffi::StateCtx) ui::OverlayEntry {
  ui::OverlayEntry{
    Modal: true,
    Child: ui::Dialog{
      Title: "Demo dialog",
      Child: ui::Text{
        Value: "Focus stays inside this dialog. Press Escape or choose Close to dismiss it.",
        SoftWrap: true,
      },
      Width: 48,
      Actions: [
        ui::Button{
          Label: "Notify",
          OnPressed: fn(ev: ui::EventContext) {
            ev.Notify("Dialog", "Action from dialog")
          },
        },
        ui::Button{Label: "Close", OnPressed: fn(ev: ui::EventContext) {
          set_dialog(c, false)
        }},
      ],
      OnDismiss: fn(ev: ui::EventContext) {
        set_dialog(c, false)
      },
    },
  }
}

fn set_mode(c: mut ffi::StateCtx, v: Str) {
  let state = ffi::StateRef<DemoState>(c)
  state.mode = v
  ffi::MarkDirty(c)
}

fn set_chat(c: mut ffi::StateCtx, v: Str) {
  let state = ffi::StateRef<DemoState>(c)
  state.chat = v
  ffi::MarkDirty(c)
}

fn submit_chat(c: mut ffi::StateCtx, value: Str) {
  let trimmed = value.trim()
  match trimmed.is_empty() {
    true => (),
    false => {
      let state = ffi::StateRef<DemoState>(c)
      state.logs.push("You: {trimmed}")
      state.logs.push("Echo: {trimmed}")
      state.chat = ""
      ffi::MarkDirty(c)
    },
  }
}

fn bold() ui::Style {
  ui::Style{Attribute: ui::AttrBold}
}

// --- pages ---

