fn animation_status(status: ui::AnimationStatus) Str {
  match status == ui::AnimationForward {
    true => "running",
    false => {
      match status == ui::AnimationCompleted {
        true => "complete",
        false => "idle",
      }
    },
  }
}

fn clamp_int(v: Int, lo: Int, hi: Int) Int {
  match v < lo {
    true => lo,
    false => {
      match v > hi {
        true => hi,
        false => v,
      }
    },
  }
}

// A "|   ◆   |" track with the diamond placed by the animation value.
fn animation_track(value: Float64, width: Int) Str {
  let raw = (value * (width - 1).to_f64()).to_int()
  let pos = clamp_int(raw, 0, width - 1)
  mut bar = "|"
  for i in 1..pos {
    bar = "{bar} "
  }
  bar = "{bar}◆"
  let rest = width - pos - 1
  for i in 1..rest {
    bar = "{bar} "
  }
  "{bar}|"
}

fn animation_page(c: mut ffi::StateCtx, theme: ui::Theme) ui::Widget {
  let anim = ffi::Animation(c)
  let value = anim.Value()
  let status = animation_status(anim.Status())
  ui::Flex{
    Axis: ui::Vertical,
    CrossAxisAlignment: ui::CrossAxisStart,
    Children: [
      ui::RichText{
        Spans: [
          ui::TextSpan{Text: "Animation", Style: bold()},
          ui::TextSpan{
            Text: "\nThis page uses a StateBase-owned AnimationController. The runner ticks it before each frame and the state is rebuilt while it is active.",
          },
        ],
        SoftWrap: true,
      },
      ui::SizedBox{Height: 1},
      ui::RichText{
        Spans: [
          ui::TextSpan{Text: "value: "},
          ui::TextSpan{Text: strconv::FormatFloat(value, 102, 2, 64), Style: bold()},
          ui::TextSpan{Text: "   status: "},
          ui::TextSpan{Text: status, Style: bold()},
        ],
      },
      ui::ConstrainedBox{
        Constraints: ui::Constraints{MaxWidth: 120},
        Child: ui::Text{Value: animation_track(value, 120), Overflow: ui::TextOverflowClip},
      },
      ui::ConstrainedBox{
        Constraints: ui::Constraints{MaxWidth: 120},
        Child: ui::ProgressBar{
          Value: value,
          GradientStart: theme.Accent,
          GradientEnd: theme.PrimaryHovered,
        },
      },
      ui::SizedBox{Height: 1},
      ui::Flex{
        Axis: ui::Horizontal,
        CrossAxisAlignment: ui::CrossAxisCenter,
        Children: [
          ui::Button{Label: "Replay", OnPressed: fn(ev: ui::EventContext) {
            anim.Forward()
          }},
          ui::SizedBox{Width: 1, Height: 1},
          ui::Button{Label: "Stop", OnPressed: fn(ev: ui::EventContext) {
            anim.Stop()
          }},
          ui::SizedBox{Width: 1, Height: 1},
          ui::Button{Label: "Reset", OnPressed: fn(ev: ui::EventContext) {
            anim.Reset()
          }},
        ],
      },
    ],
  }
}

// A PTY-backed terminal widget. exec.Command's variadic arg and term.Option
// functional options are inexpressible in Ard (ffi shim); the widget and its
// OnEvent handler — a match over the ui::Event dynamic type — stay in Ard.
fn terminal_page(theme: ui::Theme) ui::Widget {
  ui::Flex{
    Axis: ui::Vertical,
    CrossAxisAlignment: ui::CrossAxisStretch,
    Children: [
      ui::RichText{
        Spans: [
          ui::TextSpan{Text: "Terminal", Style: bold()},
          ui::TextSpan{Text: "\nThe terminal model renders through the ui framework as a focusable widget."},
        ],
        SoftWrap: true,
      },
      ui::SizedBox{Height: 1},
      ui::DecoratedBox(
        ui::Decoration{Style: ui::Style{Background: theme.Surface}, Border: ui::BorderLine(theme.Border)},
        ui::Padding(
          ui::All(1),
          ui::SizedBox{
            Width: 72,
            Height: 8,
            Child: term::Terminal{
              Command: ffi::ShellCommand(),
              Options: ffi::TerminalOptions(),
              AutoFocus: true,
              OnEvent: fn(ctx: ui::EventContext, ev: ui::Event) ui::EventResult {
                match ev {
                  term::EventNotify(e) => {
                    ctx.Notify(e.Title, e.Body)
                    ui::EventHandled
                  },
                  term::EventTitle(t) => {
                    ctx.SetTitle(t)
                    ui::EventHandled
                  },
                  _ => ui::EventIgnored,
                }
              },
            },
          },
        ),
      ),
      ui::SizedBox{Height: 1},
      ui::Text{
        Value: "Starts your shell in a PTY. Alt+k still opens the palette; page shortcuts are disabled here so shell input wins.",
        SoftWrap: true,
      },
    ],
  }
}

fn page_body(c: mut ffi::StateCtx, s: DemoState, theme: ui::Theme) ui::Widget {
  match s.page {
    1 => text_page(theme),
    2 => controls_page(c, s, theme),
    3 => lists_page(c, s, theme),
    4 => table_page(),
    5 => animation_page(c, theme),
    6 => theme_page(theme),
    7 => terminal_page(theme),
    _ => home_page(s),
  }
}

fn next_page(page: Int) Int {
  match page == 7 {
    true => 0,
    false => page + 1,
  }
}

fn previous_page(page: Int) Int {
  match page == 0 {
    true => 7,
    false => page - 1,
  }
}

fn build(c: mut ffi::StateCtx, ctx: ui::BuildContext) ui::Widget {
  let state = ffi::StateValue<DemoState>(c)
  let theme = ui::MustDepend<ui::Theme>(ctx)
  let body = ui::DecoratedBox(
    ui::Decoration{Style: ui::Style{Foreground: theme.Foreground, Background: theme.Background}},
    ui::Padding(
      ui::All(1),
      ui::Flex{
        Axis: ui::Vertical,
        CrossAxisAlignment: ui::CrossAxisStretch,
        Children: [
          header(c, state, theme),
          ui::SizedBox{Height: 1},
          ui::Padding(ui::All(1), page_body(c, state, theme)),
          ui::SizedBox{Height: 1},
          footer(state),
        ],
      },
    ),
  )
  // Modal overlays sit above the page; palette and dialog appear when opened.
  let palette_list: [ui::OverlayEntry] = match state.palette {
    true => [palette_entry(c)],
    false => [],
  }
  let dialog_list: [ui::OverlayEntry] = match state.dialog {
    true => [dialog_entry(c)],
    false => [],
  }
  mut overlays: [ui::OverlayEntry] = []
  for e in palette_list {
    overlays.push(e)
  }
  for e in dialog_list {
    overlays.push(e)
  }
  // Custom demo intents are string intent types; only the ui.Intent interface
  // wrapper (ffi::Intent) needs Go. Str literals widen into ui::IntentType
  // keys and parameters directly.
  // The palette search field and the terminal both own the keyboard, so the
  // single-key page shortcuts are suppressed there (Alt+k still toggles it).
  let keys_captured = state.palette or state.page == 7
  let shortcuts: [Str: ui::Intent] = match keys_captured {
    true => ["Alt+k": ffi::Intent("demo.command-palette")],
    false => {
      [
        "q": ffi::Intent("demo.quit"),
        "n": ffi::Intent("demo.next-page"),
        "p": ffi::Intent("demo.previous-page"),
        "Alt+k": ffi::Intent("demo.command-palette"),
      ]
    },
  }
  ui::Actions{
    Bindings: [
      "demo.quit": fn(ev: ui::EventContext, intent: ui::Intent) ui::EventResult {
        ev.Quit()
        ui::EventHandled
      },
      "demo.command-palette": fn(ev: ui::EventContext, intent: ui::Intent) ui::EventResult {
        set_palette(c, true)
        ui::EventHandled
      },
      "demo.next-page": fn(ev: ui::EventContext, intent: ui::Intent) ui::EventResult {
        set_page(c, next_page(state.page))
        ui::EventHandled
      },
      "demo.previous-page": fn(ev: ui::EventContext, intent: ui::Intent) ui::EventResult {
        set_page(c, previous_page(state.page))
        ui::EventHandled
      },
    ],
    Child: ui::Shortcuts{Bindings: shortcuts, Child: ui::Overlay{Child: body, Entries: overlays}},
  }
}

fn main() {
  let app = ffi::Stateful{
    Init: fn() Any {
      DemoState{
        page: 0,
        count: 0,
        ticks: 0,
        name: "",
        notes: "",
        done: false,
        dialog: false,
        palette: false,
        mode: "compact",
        chat: "",
        logs: ["Ada: welcome to the echo log", "Linus: submit a message below"],
      }
    },
    Build: build,
    OnTick: tick,
    Animate: true,
  }

  let _ = ui::Run(app)
}
