fn table_header(value: Str) ui::Widget {
  ui::Text{Value: value, Style: bold()}
}

fn pad_right(s: Str, n: Int) Str {
  mut out = s
  let deficit = n - s.size()
  for i in 1..deficit {
    out = "{out} "
  }
  out
}

fn theme_swatch_span(name: Str, background: ui::Color, foreground: ui::Color) ui::TextSpan {
  ui::TextSpan{
    Text: " {pad_right(name, 24)} ",
    Style: ui::Style{Foreground: foreground, Background: background},
  }
}

fn theme_text_span(name: Str, foreground: ui::Color) ui::TextSpan {
  ui::TextSpan{Text: " {pad_right(name, 24)} ", Style: ui::Style{Foreground: foreground}}
}

// Row indent (2) + a 2-space gap before each span reproduces the reference's
// "    span  span  span" spacing without a per-item index check.
fn theme_swatch_row(spans: [ui::TextSpan]) ui::Widget {
  mut row: [ui::TextSpan] = [ui::TextSpan{Text: "  "}]
  for span in spans {
    row.push(ui::TextSpan{Text: "  "})
    row.push(span)
  }
  ui::RichText{Spans: row}
}

fn theme_group(name: Str, children: [ui::Widget]) ui::Widget {
  mut kids: [ui::Widget] = [ui::RichText{Spans: [ui::TextSpan{Text: "  "}, ui::TextSpan{Text: name, Style: bold()}]}]
  for child in children {
    kids.push(child)
  }
  ui::Flex{
    Axis: ui::Vertical,
    CrossAxisAlignment: ui::CrossAxisStart,
    Children: kids,
  }
}

fn palette_scale(name: Str, scale: ui::ColorScale) ui::Widget {
  ui::RichText{
    Spans: [
      ui::TextSpan{Text: pad_right(name, 9)},
      ui::TextSpan{Text: "  ", Style: ui::Style{Background: scale.Tone50}},
      ui::TextSpan{Text: "  ", Style: ui::Style{Background: scale.Tone100}},
      ui::TextSpan{Text: "  ", Style: ui::Style{Background: scale.Tone200}},
      ui::TextSpan{Text: "  ", Style: ui::Style{Background: scale.Tone300}},
      ui::TextSpan{Text: "  ", Style: ui::Style{Background: scale.Tone400}},
      ui::TextSpan{Text: "  ", Style: ui::Style{Background: scale.Tone500}},
      ui::TextSpan{Text: "  ", Style: ui::Style{Background: scale.Tone600}},
      ui::TextSpan{Text: "  ", Style: ui::Style{Background: scale.Tone700}},
      ui::TextSpan{Text: "  ", Style: ui::Style{Background: scale.Tone800}},
      ui::TextSpan{Text: "  ", Style: ui::Style{Background: scale.Tone900}},
      ui::TextSpan{Text: "  ", Style: ui::Style{Background: scale.Tone950}},
    ],
  }
}

fn theme_page(theme: ui::Theme) ui::Widget {
  ui::Flex{
    Axis: ui::Vertical,
    CrossAxisAlignment: ui::CrossAxisStart,
    Children: [
      ui::RichText{
        Spans: [
          ui::TextSpan{Text: "Theme", Style: bold()},
          ui::TextSpan{
            Text: "\nSemantic colors are generated from the palette, then widgets derive their styles from these roles.",
          },
        ],
        SoftWrap: true,
      },
      ui::SizedBox{Height: 1},
      ui::RichText{Spans: [ui::TextSpan{Text: "Semantic colors", Style: bold()}]},
      theme_group(
        "base",
        [
          theme_swatch_row(
            [
              theme_swatch_span("Theme.Background", theme.Background, theme.Foreground),
              theme_text_span("Theme.Foreground", theme.Foreground),
              theme_swatch_span("Theme.Border", theme.Border, theme.Background),
            ],
          ),
        ],
      ),
      theme_group(
        "surface",
        [
          theme_swatch_row(
            [
              theme_swatch_span("Theme.Surface", theme.Surface, theme.Foreground),
              theme_swatch_span("Theme.SurfaceRaised", theme.SurfaceRaised, theme.Foreground),
            ],
          ),
          theme_swatch_row(
            [
              theme_swatch_span("Theme.SurfaceHovered", theme.SurfaceHovered, theme.Foreground),
              theme_swatch_span("Theme.SurfacePressed", theme.SurfacePressed, theme.Foreground),
            ],
          ),
        ],
      ),
      theme_group(
        "primary and accent",
        [
          theme_swatch_row(
            [
              theme_swatch_span("Theme.Primary", theme.Primary, theme.Foreground),
              theme_text_span("Theme.PrimaryText", theme.PrimaryText),
            ],
          ),
          theme_swatch_row(
            [
              theme_swatch_span("Theme.PrimaryHovered", theme.PrimaryHovered, theme.Foreground),
              theme_swatch_span("Theme.PrimaryPressed", theme.PrimaryPressed, theme.Foreground),
            ],
          ),
          theme_swatch_row(
            [
              theme_swatch_span("Theme.Accent", theme.Accent, theme.Foreground),
              theme_text_span("Theme.AccentText", theme.AccentText),
            ],
          ),
        ],
      ),
      theme_group(
        "state",
        [
          theme_swatch_row(
            [
              theme_swatch_span("Theme.Success", theme.Success, theme.Foreground),
              theme_text_span("Theme.SuccessText", theme.SuccessText),
            ],
          ),
          theme_swatch_row(
            [
              theme_swatch_span("Theme.Warning", theme.Warning, theme.Foreground),
              theme_text_span("Theme.WarningText", theme.WarningText),
            ],
          ),
          theme_swatch_row(
            [
              theme_swatch_span("Theme.Danger", theme.Danger, theme.Foreground),
              theme_text_span("Theme.DangerText", theme.DangerText),
            ],
          ),
        ],
      ),
      theme_group(
        "text and selection",
        [
          theme_swatch_row(
            [
              theme_text_span("Theme.MutedForeground", theme.MutedForeground),
              theme_text_span("Theme.DisabledForeground", theme.DisabledForeground),
            ],
          ),
          theme_swatch_row([theme_swatch_span("Theme.Selection", theme.Selection, theme.Foreground)]),
        ],
      ),
      ui::SizedBox{Height: 1},
      ui::RichText{Spans: [ui::TextSpan{Text: "Palette tones", Style: bold()}]},
      palette_scale("neutral", theme.Palette.Neutral),
      palette_scale("red", theme.Palette.Red),
      palette_scale("green", theme.Palette.Green),
      palette_scale("yellow", theme.Palette.Yellow),
      palette_scale("blue", theme.Palette.Blue),
      palette_scale("magenta", theme.Palette.Magenta),
      palette_scale("cyan", theme.Palette.Cyan),
    ],
  }
}

// --- chrome ---

fn tab_button(c: mut ffi::StateCtx, s: DemoState, theme: ui::Theme, label: Str, page: Int) ui::Widget {
  let tab = ui::Button{Label: label, OnPressed: fn(ev: ui::EventContext) {
    set_page(c, page)
  }}

  match s.page == page {
    true => {
      let active = ui::Theme{
        Background: theme.Background,
        Foreground: theme.Foreground,
        Surface: theme.Primary,
        SurfaceHovered: theme.PrimaryHovered,
      }

      ui::Provider<ui::Theme>{Value: active, Child: tab}
    },
    false => tab,
  }
}

