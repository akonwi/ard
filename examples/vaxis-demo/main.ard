            ui::TextSpan{Text: "\nRichText spans can mix "},
            ui::TextSpan{Text: "bold", Style: bold()},
            ui::TextSpan{Text: ", "},
            ui::TextSpan{Text: "italic", Style: ui::Style{Attribute: ui::AttrItalic}},
            ui::TextSpan{Text: ", and normal text while sharing the same selection area."},
          ],
          SoftWrap: true,
