use go:bufio
use go:fmt
use go:os
use go:strings

struct WordCount {
  word: Str,
  count: Int,
}

fn count_words(words: [Str]) [WordCount] {
  mut counts: [Str: Int] = [:]

  for word in words {
    counts.set(word, counts.get(word).or(0) + 1)
  }

  mut res: [WordCount] = []
  for word, count in counts {
    res.push(WordCount{word: word, count: count})
  }
  res
}

fn main() {
  mut scanner = bufio::NewScanner(os::Stdin)

  fmt::Println("Enter some text to analyze:")
  if scanner.Scan() {
    let text = strings::TrimSpace(scanner.Text())
    let words = strings::Split(text, " ")
    mut word_counts = count_words(words)

    fmt::Println("\nWord Frequency Analysis:")
    fmt::Println("------------------------")
    fmt::Println("Total words: {words.size()}")
    fmt::Println("Unique words: {word_counts.size()}")

    fmt::Println("\nMost frequent words:")
    word_counts.sort(
      fn(a: WordCount, b: WordCount) Bool {
        a.count > b.count
      },
    )

    for entry, rank in word_counts {
      fmt::Println("{rank + 1}. {entry.word}: {entry.count}")
    }
  } else {
    fmt::Println("Unable to read input")
  }
}

main()
