use go:fmt

trait Display {
  fn display() Str
}

struct Book {
  title: Str,
  author: Str,
}

impl Display for Book {
  fn display() Str {
    "Book: " + self.title + " by " + self.author
  }
}

fn show(item: Display) {
  fmt::Println(item.display())
}

fn main() {
  let book = Book{title: "The Hobbit", author: "J.R.R. Tolkien"}
  show(book)
}
