use go:fmt

enum Color {
  Red,
  Yellow,
  Green,
}

fn get_meaning(light: Color) Str {
  match light {
    // map a pattern to a simple expression
    // or a block
    // use _ for catch alls
    Color::Red => "Stop",
    Color::Yellow => "Yield",
    _ => "Go",
  }
}

fn main() {
  fmt::Println("Yellow means {get_meaning(Color::Yellow)}")
}
