use go:fmt

fn main() {
  mut count = 0
  while count <= 9 {
    count = count + 1
  }

  let is_true = false
  while is_true or count > 0 {
    count = count - 1
  }

  count = 3
  while count > 0 {
    count = count - 1
  }

  for i in 1..10 {
    fmt::Println(i)
  }

  fmt::Println("counting from 1 to {count + 3}")
  for i in 1..count + 3 {
    fmt::Println(i)
  }
}
