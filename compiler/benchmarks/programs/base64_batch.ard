use ard/base64
use ard/io

fn build_payload(i: Int) Str {
  "row:" + i.to_str() + ":" + (i * 17 % 1009).to_str() + ":ard-benchmark"
}

fn run_batch(count: Int) Int {
  mut checksum = 0
  for i in 0..count {
    let payload = build_payload(i)
    let encoded = base64::encode(payload)
    let decoded = base64::decode(encoded).expect("valid base64")
    let encoded_url = base64::encode_url(decoded, true)
    let decoded_url = base64::decode_url(encoded_url, true).expect("valid base64url")
    checksum =+ encoded.size() + decoded_url.size()
    if decoded_url.contains("ard") {
      checksum =+ i % 97
    }
  }
  checksum
}

fn main() {
  io::print(run_batch(12000))
}
