use go:github.com/akonwi/ard/std_lib/ffi
use go:strings

// defines converting to a string
trait ToString {
  fn to_str() Str
}

fn split(input: Str, delimiter: Str) [Str] {
  strings::Split(input, delimiter)
}
fn from_bytes(bytes: [Byte]) Str!Str {
  ffi::StrFromUtf8(bytes)
}

fn from_runes(runes: [Rune]) Str!Str {
  ffi::StrFromRunes(runes)
}
