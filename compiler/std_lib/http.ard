use ard/dynamic
use ard/ffi
use ard/maybe
use ard/string as Str

use go:net/http as gohttp

enum Method {
  Get,
  Post,
  Put,
  Del,
  Patch,
  Options,
}

impl Str::ToString for Method {
  fn to_str() Str {
    match self {
      Method::Get => gohttp::MethodGet,
      Method::Post => gohttp::MethodPost,
      Method::Put => gohttp::MethodPut,
      Method::Del => gohttp::MethodDelete,
      Method::Patch => gohttp::MethodPatch,
      Method::Options => gohttp::MethodOptions,
    }
  }
}

private type RawRequest = mut gohttp::Request
private type RawResponse = mut gohttp::Response

struct Request {
  method: Method,
  url: Str,
  headers: [Str: Str],
  body: Dynamic?,
  timeout: Int?,

  // inbound requests have the *http.Request
  raw: RawRequest?,
}

impl Request {
  fn path() Str? {
    let raw = try self.raw
    match ffi::is_nil(raw) {
      true => maybe::some(""),
      false => {
        match ffi::is_nil(raw.URL) {
          true => maybe::some(""),
          false => maybe::some(raw.URL.Path),
        }
      },
    }
  }

  fn path_param(name: Str) Str {
    let raw = try self.raw -> _ { "" }
    match ffi::is_nil(raw) {
      true => "",
      false => raw.PathValue(name),
    }
  }

  fn query_param(name: Str) Str {
    let raw = try self.raw -> _ { "" }
    match ffi::is_nil(raw) {
      true => "",
      false => {
        match ffi::is_nil(raw.URL) {
          true => "",
          false => raw.URL.Query().Get(name),
        }
      },
    }
  }
}

struct Response {
  status: Int,
  headers: [Str: Str],
  body: Str,
}

fn Response::new(status: Int, body: Str) Response {
  Response{
    status: status,
    body: body,
    headers: [:],
  }
}

impl Response {
  fn is_ok() Bool {
    gohttp::StatusOK <= self.status < gohttp::StatusMultipleChoices
  }
}

// HTTP client FFI functions - operate on opaque RawResponse handle
// body is Dynamic (nil means no body)
private extern fn http_do(method: Str, url: Str, body: Dynamic, headers: [Str: Str], timeout: Int?) RawResponse!Str = "HTTP_Do"
private extern fn http_response_headers(resp: RawResponse) [Str: Str] = "HTTP_ResponseHeaders"
private extern fn http_response_body(resp: RawResponse) Str!Str = "HTTP_ResponseBody"
private extern fn http_response_close(resp: RawResponse) Void = "HTTP_ResponseClose"

fn send(req: Request, timeout: Int?) Response!Str {
  let method = req.method.to_str()
  let effective_timeout = match timeout {
    t => maybe::some(t),
    _ => req.timeout,
  }

  // Extract body: Dynamic? -> Dynamic (nil means no body)
  let request_body: Dynamic = match req.body {
    d => d,
    _ => dynamic::from_void(),
  }

  // Make the HTTP request
  let resp = try http_do(method, req.url, request_body, req.headers, effective_timeout)

  // Extract response data
  let status = match ffi::is_nil(resp) {
    true => 0,
    false => resp.StatusCode,
  }
  let headers = http_response_headers(resp)
  let body_result = http_response_body(resp)

  // Clean up resources
  http_response_close(resp)

  // Build response
  let response_body = try body_result
  Result::ok(
    Response{
      status: status,
      headers: headers,
      body: response_body,
    },
  )
}

type HandlerFn = fn(Request, mut Response)

extern fn serve(port: Int, handlers: [Str: HandlerFn]) Void!Str = "HTTP_Serve"
