use ard/maybe
use ard/testing

use go:strconv

fn from_str(str: Str) Int? {
  let value = try strconv::Atoi(str) -> _ { maybe::none() }
  maybe::some(value)
}

test fn test_from_str_valid_int() Void!Str {
  testing::assert(from_str("42").or(0) == 42, "from_str should parse valid integers")
}

test fn test_from_str_invalid_int_returns_none() Void!Str {
  testing::assert(
    from_str("not an int").is_none(),
    "from_str should return none for invalid integers",
  )
}
