use go:ard/ffi as host

use go:time

// start runs `do` concurrently on a new goroutine. It is fire-and-forget;
// coordinate completion or results with channels (see ard/channel).
fn start(do: fn() Void) {
  host::Spawn(do)
}

// sleep blocks the current task for the given number of nanoseconds.
fn sleep(nanoseconds: Int) {
  time::Sleep(nanoseconds)
}
