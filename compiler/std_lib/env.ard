use ard/testing

use go:os

// Standard library Environment module implemented with FFI
// Provides access to environment variables

fn get(key: Str) Str? {
  os::LookupEnv(key)
}

test fn test_get_missing_var_returns_none() Void!Str {
  testing::assert(
    get("ARD_TEST_MISSING_ENV_VAR").is_none(),
    "Expected missing env var to return none",
  )
}
