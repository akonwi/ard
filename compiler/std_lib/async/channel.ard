extern type Chan<$T>

private extern fn chan_send<$T>(ch: Chan<$T>, value: $T) Bool = "ChannelSend"
private extern fn chan_recv<$T>(ch: Chan<$T>) $T? = "ChannelRecv"
private extern fn chan_close<$T>(ch: Chan<$T>) Bool = "ChannelClose"

struct Channel {
  chan: Chan<$T>,
}

impl Channel {
  fn send(value: $T) Bool {
    chan_send(self.chan, value)
  }

  fn recv() $T? {
    chan_recv(self.chan)
  }

  fn close() Bool {
    chan_close(self.chan)
  }
}

extern fn new<$T>(size: Int?) Channel<$T> = "ChannelNew"
